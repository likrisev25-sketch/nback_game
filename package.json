{
  "name": "nback-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:socket": "node server.js",
    "build": "next build",
    "start": "next start",
    "start:socket": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "db:setup": "node scripts/setup-db.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "secret:generate": "node -e \"console.log('BETTER_AUTH_SECRET=' + require('crypto').randomBytes(32).toString('base64'))\"",
    "docker:build": "docker build -t nback-game .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/db.sqlite:/app/db.sqlite -e NODE_ENV=production nback-game",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@better-auth/core": "^1.6.9",
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.100.8",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.40",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
